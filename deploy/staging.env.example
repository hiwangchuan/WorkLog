APP_NAME=WorkLog AI Staging
APP_ENV=staging
APP_DEBUG=false
APP_ENV_FILE=.env.staging
COMPOSE_PROJECT_NAME=worklog_staging
CONTAINER_PREFIX=worklog-staging
APP_SECRET_KEY=please-change-this-staging-secret
APP_BASE_URL=http://47.237.24.164:18081

POSTGRES_PASSWORD=please-change-this-staging-password
DATABASE_URL=postgresql://worklog:please-change-this-staging-password@postgres:5432/worklog

REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=please-change-this-staging-jwt-secret
JWT_EXPIRE_MINUTES=1440

UPLOAD_DRIVER=local
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=50

AI_ENABLE=true
AI_DEFAULT_PROVIDER=openai_compatible
AI_REQUEST_TIMEOUT=60
AI_DESENSITIZATION_DEFAULT=true

CONFIG_ENCRYPTION_KEY=please-change-this-staging-32-byte-key

CORS_ORIGINS=http://47.237.24.164:18081,http://localhost:18081,http://127.0.0.1:18081
HOST_PORT=18081
